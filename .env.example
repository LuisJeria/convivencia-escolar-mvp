# Base de datos
# Local: PostgreSQL en Docker (ver docker-compose.yml)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/convivencia"

# Para deploy en Vercel, usa Neon (https://neon.tech) y cambia esta variable:
# 1. Crea una cuenta en https://neon.tech (plan gratuito)
# 2. Crea un proyecto y copia el connection string (incluye ?sslmode=require)
# 3. Configúralo en Vercel → Project Settings → Environment Variables
# DATABASE_URL="postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/convivencia?sslmode=require"
